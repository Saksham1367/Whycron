# syntax=docker/dockerfile:1.7
# Whycron self-host — web (dashboard SPA) image
#
# Two stages:
#   1. ``build`` runs Vite + tsc to produce a static bundle in /app/dist
#   2. ``runtime`` is nginx serving that bundle with SPA fallback
#
# The bundle is built with the Supabase + API URLs baked in via Vite
# env vars. Self-hosters configure them in selfhost/.env before
# ``docker compose build``.

FROM node:20-bookworm-slim AS build
WORKDIR /app

# Build args become VITE_* env vars at build time.
ARG VITE_API_URL=""
ARG VITE_SUPABASE_URL=""
ARG VITE_SUPABASE_ANON_KEY=""
ARG VITE_SENTRY_DSN=""
ARG VITE_POSTHOG_KEY=""
ENV VITE_API_URL=$VITE_API_URL \
    VITE_SUPABASE_URL=$VITE_SUPABASE_URL \
    VITE_SUPABASE_ANON_KEY=$VITE_SUPABASE_ANON_KEY \
    VITE_SENTRY_DSN=$VITE_SENTRY_DSN \
    VITE_POSTHOG_KEY=$VITE_POSTHOG_KEY

COPY apps/web/package.json apps/web/package-lock.json ./
RUN --mount=type=cache,target=/root/.npm npm ci

COPY apps/web/ ./
RUN npm run build

FROM nginx:1.27-alpine AS runtime
COPY --from=build /app/dist /usr/share/nginx/html
COPY selfhost/nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
