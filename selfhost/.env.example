# ─────────────────────────────────────────────────────────────────────────────
# Whycron self-host configuration.
#
# Copy this file to .env, then edit the values below. Every variable
# marked REQUIRED must have a value before ``docker compose up``.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED. The password Postgres will use inside the compose network.
# Pick anything strong; it's only used between containers.
POSTGRES_PASSWORD=change-me

# REQUIRED. Fernet key for encrypting at-rest secrets (currently used for
# notification channel configs, e.g. webhook signing secrets). Generate one:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# REQUIRED. HMAC secret signed onto every outbound webhook delivery so
# downstream receivers can verify the payload's origin.
WEBHOOK_SIGNING_SECRET=

# REQUIRED. A Supabase project provides authentication. Sign up at
# https://supabase.com (free), create a project, then:
#   1. Authentication → Providers → enable Email (and Google if you want
#      OAuth). Add http://localhost:8080/auth/callback (or your real URL)
#      to the redirect allow-list.
#   2. Settings → API → copy "Project URL" and the "anon" / "public" key
#      into the two variables below.
#   3. Settings → API → JWT Settings → copy the JWT Secret into
#      SUPABASE_JWT_SECRET *if* your project still uses HS256 (legacy
#      default). Modern Supabase projects use RS256 and resolve the
#      signing key automatically; leave the secret blank in that case.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_JWT_SECRET=

# ─── Optional: outbound email via Brevo ──────────────────────────────────────
# Leave BREVO_API_KEY empty to disable email notification channels. The
# rest of the system continues to work; users will only see webhook /
# Discord channel options.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=alerts@whycron.local
BREVO_SENDER_NAME=Whycron

# ─── Where Whycron will live ─────────────────────────────────────────────────
# These are the URLs users will hit from outside the compose network.
# For a local trial keep the defaults. For a real deployment behind a
# reverse proxy, set them to your public URLs (e.g. APP_URL=
# https://whycron.acme.internal and FRONTEND_URL=https://status.acme.internal).
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8080
VITE_API_URL=http://localhost:8000

# ─── Host port bindings ──────────────────────────────────────────────────────
# Override these if the defaults clash with something else on your host.
# All ports are bound to 127.0.0.1 only — put a reverse proxy in front to
# expose to the network.
WEB_PORT=8080
API_PORT=8000
POSTGRES_PORT=5433
REDIS_PORT=6380

# ─── Things you DO NOT need to set ───────────────────────────────────────────
# Whycron self-host explicitly disables the SaaS-only differentiators:
#   - AI failure explanations (Anthropic)
#   - Polished Slack OAuth + threaded alerts
#   - Polar.sh billing
# These run only on the hosted version at https://whycron.com.
# Setting their env vars here has no effect; the API ignores them when
# SELF_HOST_MODE=true.
