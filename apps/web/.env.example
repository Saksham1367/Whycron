# Whycron frontend — Vite env vars must use the VITE_ prefix.
# Copy this file to apps/web/.env and fill in real values from your
# main project .env (same Supabase project).

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_URL=http://localhost:8000

# === Error tracking (Sentry, web project) ===
# Different DSN from the backend; same Sentry org. Empty = Sentry disabled.
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# === Analytics (PostHog, project public key) ===
# Same value as the backend's POSTHOG_API_KEY. Empty = PostHog disabled.
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com
