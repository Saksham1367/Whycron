# Whycron — environment template
# Copy this file to `.env` and fill in real values.
# Never commit `.env`. See SECURITY.md and CONTEXT.md §7.1.

# === App Config ===
APP_ENV=development                 # development | staging | production
APP_URL=http://localhost:8000
# Dashboard / SPA origin — used to build OAuth + billing redirect targets.
FRONTEND_URL=http://localhost:5173
APP_PORT=8000
LOG_LEVEL=INFO

# === Database ===
# Async driver (asyncpg) is added automatically if you supply a plain
# `postgresql://` URL. `postgresql+asyncpg://` also works directly.
DATABASE_URL=postgresql://whycron:whycron_local_dev@localhost:5432/whycron
REDIS_URL=redis://localhost:6379/0

# === Auth (Supabase) ===
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # backend only — never expose to the browser
# Only needed if your project signs JWTs with HS256 (legacy default).
# RS256 projects verify via the JWKS endpoint and do not need this.
# Find it at Supabase dashboard → Settings → API → JWT Secret.
SUPABASE_JWT_SECRET=

# === LLM (Anthropic) ===
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_DEFAULT=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_PREMIUM=claude-sonnet-4-6

# === Email (Brevo) ===
BREVO_API_KEY=
BREVO_SENDER_EMAIL=alerts@whycron.dev
BREVO_SENDER_NAME=Whycron

# === Payments (Polar.sh) ===
POLAR_API_KEY=
POLAR_WEBHOOK_SECRET=
POLAR_PRODUCT_PRO_ID=
POLAR_PRODUCT_TEAM_ID=
# Sandbox host while developing; switch to https://api.polar.sh in production.
POLAR_API_BASE=https://sandbox-api.polar.sh

# === Error tracking (Sentry) ===
# Three separate projects so issues are grouped by where they fired.
# The web DSN lives in apps/web/.env as VITE_SENTRY_DSN.
SENTRY_DSN=
SENTRY_WORKER_DSN=
SENTRY_ENVIRONMENT=development

# === Analytics (PostHog) ===
# Use the project's PUBLIC key (starts with `phc_`) — same value the
# frontend uses. Host depends on PostHog region (us / eu).
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com

# === Security ===
# Generate with: openssl rand -hex 32
WEBHOOK_SIGNING_SECRET=
JWT_AUDIENCE=whycron-api
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# === Slack (V2) ===
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
